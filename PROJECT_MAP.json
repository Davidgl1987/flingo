    "tests": "tests/run-tests.ts",
    "manual_tests": "tests/manual/PLAYTEST_CHECKLIST.md",
    "definitions": "docs/definitions",
    "ai_instructions": "docs/instructions",
    "agent_roles": "docs/agents",
    "skills": "docs/skills",
    "docs": "docs"
  },
  "current_scope": [
    "drag-release movement",
    "room-based combat",
    "body/projectile risk-reward",
    "hazards",
    "simple upgrades",
    "manual rooms"
  ],
  "out_of_scope_for_now": [
    "final art",
    "monetization",
    "online",
    "procedural generation",
    "complex inventory",
    "full Capacitor integration"
