{
  "name": "slingshot-dungeon-mvp",
  "version": "0.1.1",
  "private": true,
  "scripts": {
    "dev": "vite --host 0.0.0.0",
    "build": "tsc -b && vite build",
    "preview": "vite preview --host 0.0.0.0",
    "test": "tsc -p tsconfig.test.json && node dist-tests/tests/run-tests.js",
