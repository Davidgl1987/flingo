  },
  "dependencies": {
    "@react-three/fiber": "^9.1.2",
    "@vitejs/plugin-react": "^4.6.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "three": "^0.177.0",
    "vite": "^6.3.5",
    "zustand": "^5.0.5"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.3.1",
    "@types/react": "^19.1.8",
    "@types/react-dom": "^19.1.6",
    "@types/three": "^0.177.0",
    "tailwindcss": "^4.3.1",
    "typescript": "^5.8.3"
  }
}
