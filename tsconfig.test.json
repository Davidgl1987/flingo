{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022", "DOM"],
    "module": "CommonJS",
    "moduleResolution": "Node",
    "strict": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "skipLibCheck": true,
    "outDir": "dist-tests",
    "rootDir": "."
  },
  "include": ["src/game/core/**/*.ts", "src/game/physics/**/*.ts", "tests/**/*.ts"]
}
